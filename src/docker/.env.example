# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Postgres (defaults are fine for a single personal deployment).
POSTGRES_USER=conjugate
POSTGRES_PASSWORD=change-me
POSTGRES_DB=conjugate

# Signs the session cookie. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Google OAuth (OIDC) credentials from the Google Cloud console.
# Authorized redirect URI: https://conjugate.themullers.org/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: restrict sign-in to these emails (comma-separated). Empty = any Google account.
ALLOWED_EMAILS=

# --- Local development only ---
# DEV_LOGIN=1 signs in a fake local user, bypassing Google. Never set in prod.
# SESSION_HTTPS_ONLY=0 lets the session cookie work over plain http://localhost.
# DEV_LOGIN=1
# SESSION_HTTPS_ONLY=0
